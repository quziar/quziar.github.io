import sqlite3
import os
import pandas as pd

# 定義資料庫檔案路徑和 Excel 檔案路徑
db_path = r"C:\Users\allen\sqlite3\question_bank.db"
excel_path = r"C:\Users\allen\sqlite3\questions.xlsx"

# 檢查資料庫檔案是否存在
if not os.path.exists(db_path):
    print(f"錯誤：位於 {db_path} 的資料庫不存在。")
else:
    # 連接到 SQLite 資料庫
    conn = sqlite3.connect(db_path)
    print("正在連接到資料庫...")

    try:
        # 創建一個游標物件，用來執行 SQL 查詢
        cursor = conn.cursor()

        # 執行 SQL 查詢來創建資料表 (如果資料表尚未存在)
        cursor.execute('''
        CREATE TABLE IF NOT EXISTS questions (
            id INTEGER PRIMARY KEY AUTOINCREMENT,
            question_text TEXT NOT NULL,
            option_a TEXT NOT NULL,
            option_b TEXT NOT NULL,
            option_c TEXT NOT NULL,
            option_d TEXT NOT NULL,
            correct_answer TEXT NOT NULL
        )
        ''')

        # 使用 pandas 讀取 Excel 檔案，並指定標題行
        df = pd.read_excel(excel_path, header=0)

        # 確保只選擇需要的六個欄位，如果存在
        required_columns = ['題目內容', 'A', 'B', 'C', 'D', '解答']
        existing_columns = [col for col in required_columns if col in df.columns]
        df = df[existing_columns]
        df.columns = ['question_text', 'option_a', 'option_b', 'option_c', 'option_d', 'correct_answer'][:len(existing_columns)]

        # 檢查 Excel 檔案中的每一列並插入到資料庫
        for index, row in df.iterrows():
            # 檢查 question_text 欄位是否為空
            if pd.isnull(row['question_text']):
                print(f"錯誤：第 {index} 行的 question_text 欄位為空。")
                continue

            # 檢查題目是否已存在於資料庫中
            cursor.execute('''
            SELECT id FROM questions WHERE question_text = ?
            ''', (row['question_text'],))
            existing_question = cursor.fetchone()

            if existing_question:
                # 刪除已存在的重複題目
                cursor.execute('''
                DELETE FROM questions WHERE id = ?
                ''', (existing_question[0],))
                print(f"刪除第 {index} 行的重複題目。")

            # 插入新的題目
            cursor.execute('''
            INSERT INTO questions (question_text, option_a, option_b, option_c, option_d, correct_answer)
            VALUES (?, ?, ?, ?, ?, ?)
            ''', (row['question_text'], row.get('option_a', ''), row.get('option_b', ''), row.get('option_c', ''), row.get('option_d', ''), row.get('correct_answer', '')))

        # 提交改動
        conn.commit()

        # 查詢資料庫中的所有題目
        cursor.execute('SELECT * FROM questions')
        rows = cursor.fetchall()

        # 顯示所有題目
        for row in rows:
            print(row)

    except Exception as e:
        print(f"發生錯誤：{e}")

    finally:
        # 關閉游標和資料庫連接
        cursor.close()
        conn.close()
        print("資料庫連接已關閉。")
